"""
Server for text Emotion Detection
"""
from flask import Flask, render_template, request
from EmotionDetection.emotion_detection import emotion_detector

app = Flask("Emotion Detector")

@app.route("/")
def home_route():
    """
    Renders home route
    """
    return render_template("index.html")

@app.route("/emotionDetector")
def emotion_analyzer():
    """
    Analyzes text to check on emotions
    Request Arguments:
        textToAnalyze: string, text to be analized for emotions
    Returns:
        result: string, string with a breakdown of the emotions
    """
    text_to_analyze = request.args.get("textToAnalyze")
    analyzed_text = emotion_detector(text_to_analyze)
    if analyzed_text.get('dominant_emotion') is None:
        result = "Invalid text! Please try again!."
    else:
        result = (
            f"For the given statement, the system response is "
            f"'anger': {analyzed_text['anger']}, "
            f"'disgust': {analyzed_text['disgust']}, "
            f"'fear': {analyzed_text['fear']}, "
            f"'joy': {analyzed_text['joy']} and "
            f"'sadness': {analyzed_text['sadness']}. "
            f"The dominant emotion is {analyzed_text['dominant_emotion']}.\n"
            f"{analyzed_text}"
        )
    return result

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5000)
